# Remote CCTV home occupancy API base URL (CORS proxy target)
NUXT_API_BASE_URL=http://localhost:8000

# Front-end dashboard top-left title override
NUXT_PUBLIC_PANEL_TITLE="CCTV OCCUPANCY PANEL"

# Refresh rate in milliseconds for the live CCTV preview feed
# NUXT_PUBLIC_CCTV_REFRESH_INTERVAL=2000

# Polling frequency in milliseconds for system occupancy status
# NUXT_PUBLIC_STATUS_POLL_INTERVAL=3000

# Polling frequency in milliseconds for the recent event logs list
# NUXT_PUBLIC_EVENTS_POLL_INTERVAL=5000
